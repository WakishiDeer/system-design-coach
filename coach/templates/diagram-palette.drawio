        <mxCell id="subtitle" value="Reuse these styles so write vs read paths are obvious at a glance. Components are colored by type; edges show direction by color &amp; line style." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=2;fontColor=#555555" vertex="1" parent="1">
