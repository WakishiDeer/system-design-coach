        <mxCell id="title" value="System-Design Diagram Palette — copy (Ctrl/Cmd+C) a shape or arrow here, paste (Ctrl/Cmd+V) into your design" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=15;fontStyle=1" vertex="1" parent="1">
